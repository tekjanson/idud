{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aggregated Metrics Schema",
  "description": "Aggregated metrics summarizing training run performance over time",
  "type": "object",
  "properties": {
    "metric_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this metrics snapshot"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when these metrics were computed"
    },
    "period": {
      "type": "string",
      "description": "Time period these metrics cover (e.g., 'daily', 'weekly', 'all-time')"
    },
    "time_window": {
      "type": "object",
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time",
          "description": "Start of the time window"
        },
        "end": {
          "type": "string",
          "format": "date-time",
          "description": "End of the time window"
        }
      },
      "required": ["start", "end"]
    },
    "total_repos": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of unique repositories tested"
    },
    "total_predictions": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of individual predictions made"
    },
    "avg_precision": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Average precision across all predictions"
    },
    "avg_recall": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Average recall across all predictions"
    },
    "avg_f1": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Average F1 score across all predictions"
    },
    "improvement_over_time": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "checkpoint": {
            "type": "string",
            "format": "date-time",
            "description": "Time checkpoint"
          },
          "avg_f1": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["checkpoint", "avg_f1"]
      },
      "description": "Historical F1 score progression over time"
    },
    "percentiles": {
      "type": "object",
      "properties": {
        "p50_f1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "p75_f1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "p90_f1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "p95_f1": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "description": "F1 percentiles for distribution analysis"
    }
  },
  "required": [
    "metric_id",
    "generated_at",
    "period",
    "time_window",
    "total_repos",
    "total_predictions",
    "avg_precision",
    "avg_recall",
    "avg_f1"
  ],
  "additionalProperties": false
}
