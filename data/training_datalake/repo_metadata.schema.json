{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Metadata Schema",
  "description": "Metadata about repositories used for training the idud self-validation system",
  "type": "object",
  "properties": {
    "url": {
      "type": "string",
      "description": "HTTPS URL of the repository"
    },
    "owner": {
      "type": "string",
      "description": "Repository owner (username or organization)"
    },
    "name": {
      "type": "string",
      "description": "Repository name"
    },
    "stars": {
      "type": "integer",
      "description": "Number of GitHub stars",
      "minimum": 0
    },
    "forks": {
      "type": "integer",
      "description": "Number of GitHub forks",
      "minimum": 0
    },
    "language": {
      "type": "string",
      "description": "Primary programming language"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last commit"
    },
    "issue_count": {
      "type": "integer",
      "description": "Total number of open issues",
      "minimum": 0
    },
    "pr_count": {
      "type": "integer",
      "description": "Total number of open pull requests",
      "minimum": 0
    },
    "added_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when repo was added to training datalake"
    },
    "ingestion_status": {
      "type": "string",
      "enum": ["pending", "ingested", "failed"],
      "description": "Status of repository ingestion"
    }
  },
  "required": ["url", "owner", "name", "language", "added_at"],
  "additionalProperties": false
}
