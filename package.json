{
  "name": "idud",
  "version": "0.1.0",
  "description": "I Don't Understand Databases - A token-efficient concept mapping tool for understanding complex systems",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "ingest:repo": "node dist/cli/ingest-repo.js",
    "ingest:docs": "node dist/cli/ingest-docs.js",
    "ingest:knowledge": "node dist/cli/ingest-knowledge.js",
    "validate": "node dist/cli/validate.js",
    "index": "node dist/cli/index.js"
  },
  "keywords": [
    "database",
    "knowledge-graph",
    "concept-mapping",
    "AI-efficiency",
    "documentation",
    "schema"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^0.34.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "vitest": "^0.34.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
