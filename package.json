{
  "name": "idud",
  "version": "0.1.0",
  "description": "I Don't Understand Databases - A token-efficient concept mapping tool for understanding complex systems",
  "type": "module",
  "scripts": {
    "build": "cargo build --release",
    "dev": "cargo build",
    "test": "cargo test --all",
    "test:coverage": "cargo tarpaulin --out Html",
    "lint": "cargo clippy -- -D warnings",
    "fmt": "cargo fmt",
    "ingest:repo": "cargo run --release -- ingest-repo",
    "ingest:docs": "cargo run --release -- ingest-docs",
    "validate": "cargo run --release -- validate",
    "query": "cargo run --release -- query",
    "ui": "cd ui && npm run dev"
  },
  "keywords": [
    "database",
    "knowledge-graph",
    "concept-mapping",
    "ai-efficiency",
    "documentation",
    "schema",
    "rust"
  ],
  "author": "",
  "license": "MIT"
}
