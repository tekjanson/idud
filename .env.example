# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/idud
# or for Neo4j: neo4j+s://username:password@your-database-host:7687

# API Keys
OPENAI_API_KEY=sk-...
# or for local embeddings: OLLAMA_BASE_URL=http://localhost:11434

# Application
NODE_ENV=development
PORT=3000

# GitHub Integration (for repo ingestion)
GITHUB_TOKEN=ghp_...

# Search Configuration
ENABLE_SEMANTIC_SEARCH=true
EMBEDDINGS_BATCH_SIZE=100

# Logging
LOG_LEVEL=debug
